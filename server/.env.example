# 이 파일은 템플릿입니다. 실제 운영값은 git 에 커밋하지 않습니다.
# 최초 배포 시 deploy.sh 가 이 파일을 호스트의 <APP_DIR>/.env 로 복사하므로,
# 그 .env 파일을 서버에서 직접 편집해서 비밀값을 설정하세요.
API_KEY=change-me
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
DEFAULT_MODEL=opus
CLAUDE_CLI_PATH=claude
CLAUDE_TIMEOUT=300
HOST=0.0.0.0
PORT=9091
